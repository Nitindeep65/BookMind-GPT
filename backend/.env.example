# NVIDIA (OpenAI-compatible)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_EMBEDDING_INPUT_TYPE=query
NVIDIA_EMBEDDING_TRUNCATE=NONE
NVIDIA_EMBEDDING_ENCODING_FORMAT=float

# Backend security and deployment
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
BACKEND_API_KEY=

# Vector DB toggle
# true  -> use local Chroma persistent store
# false -> do not store/retrieve vectors
VECTOR_DB_ENABLED=false

# Optional Chroma Cloud settings (currently unused unless client is switched)
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
