# NVIDIA (OpenAI-compatible)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_EMBEDDING_INPUT_TYPE=query
NVIDIA_EMBEDDING_TRUNCATE=NONE
NVIDIA_EMBEDDING_ENCODING_FORMAT=float

# Backend security and deployment
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
# Optional regex for dynamic hosts (e.g., all Vercel previews):
# BACKEND_CORS_ORIGIN_REGEX=^https://.*\\.vercel\\.app$
BACKEND_CORS_ORIGIN_REGEX=
BACKEND_API_KEY=

# Guest session isolation
# Each guest gets a unique session cookie and vectors are isolated by session_id.
GUEST_SESSION_COOKIE_NAME=bookmind_guest_sid
# Session expires after N seconds of inactivity.
GUEST_SESSION_TTL_SECONDS=1800
# auto -> secure on HTTPS, non-secure on HTTP localhost.
GUEST_SESSION_COOKIE_SECURE=auto
# Optional override: lax | strict | none (auto defaults: none for secure, lax otherwise).
GUEST_SESSION_COOKIE_SAMESITE=

# Vector DB toggle
# true  -> use local Chroma persistent store
# false -> do not store/retrieve vectors
VECTOR_DB_ENABLED=false
# Optional explicit Chroma data path (e.g., /tmp/chroma_store on Render)
CHROMA_PERSIST_DIR=

# Optional Chroma Cloud settings (currently unused unless client is switched)
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
